# ─── pi coding agent – environment variable reference ─────────────────────────
# Copy this file to .env and fill in the values you need.
# Only the variables you actually use need to be set; everything else is optional.

# ─── Provider & model selection ───────────────────────────────────────────────
# Which provider to use. Supported values:
#   anthropic | openai | google | azure-openai | amazon-bedrock |
#   google-vertex | mistral | groq | cerebras | xai | openrouter |
#   vercel-ai-gateway | zai | opencode | opencode-go | huggingface |
#   kimi-coding | minimax
PI_PROVIDER=anthropic

# Model ID or pattern, e.g. "claude-sonnet-4-5", "gpt-4o", "gemini-2.5-pro"
# Use "provider/model" notation to skip --provider, e.g. "openai/gpt-4o"
PI_MODEL=claude-sonnet-4-5

# Thinking / reasoning level: off | minimal | low | medium | high | xhigh
PI_THINKING=

# Run mode: leave empty for interactive, or set to "print", "json", or "rpc"
PI_MODE=

# Comma-separated model patterns for Ctrl+P cycling, e.g. "claude-*,gpt-4o"
PI_MODELS=

# Set to 1 to automatically resume the most recent session
PI_CONTINUE=

# Non-empty string: run this single prompt non-interactively and exit
PI_PROMPT=

# ─── Tools ────────────────────────────────────────────────────────────────────
# Comma-separated list of built-in tools to enable.
# Available: read, bash, edit, write, grep, find, ls
# Default (when empty): read,bash,edit,write
PI_TOOLS=

# Set to 1 to disable ALL built-in tools (extension tools still work).
# PI_TOOLS is ignored when PI_NO_TOOLS=1.
PI_NO_TOOLS=

# ─── Session ──────────────────────────────────────────────────────────────────
# Set to 1 to run in ephemeral mode – session is not saved to disk
PI_NO_SESSION=

# Custom session storage directory inside the container (e.g. /agent/sessions)
PI_SESSION_DIR=

# ─── System prompt ────────────────────────────────────────────────────────────
# Replace the default pi system prompt entirely (context files & skills still appended)
PI_SYSTEM_PROMPT=

# Append extra instructions to the default system prompt without replacing it
PI_APPEND_SYSTEM_PROMPT=

# ─── Resources ────────────────────────────────────────────────────────────────
# Set to 1 to disable discovery of extensions / skills / prompt templates
PI_NO_EXTENSIONS=
PI_NO_SKILLS=
PI_NO_PROMPT_TEMPLATES=

# ─── Misc ─────────────────────────────────────────────────────────────────────
# Set to 1 for verbose startup output
PI_VERBOSE=

# Direct API key – overrides the provider-specific key env var (e.g. ANTHROPIC_API_KEY).
# Useful when injecting a single secret regardless of provider.
PI_API_KEY=

# ─── Agent config ─────────────────────────────────────────────────────────────
# Working directory inside the container (default: /app)
CWD=/app

# Override the config/data directory (default: ~/.pi/agent inside the container)
PI_CODING_AGENT_DIR=

# Set to 1 to skip the version check on startup
PI_SKIP_VERSION_CHECK=

# Set to "long" for extended prompt caching (Anthropic: 1 h, OpenAI: 24 h)
PI_CACHE_RETENTION=

# ─── API keys ─────────────────────────────────────────────────────────────────
# Uncomment and fill in the key(s) for the provider(s) you want to use.
# Resolution order: --api-key flag > auth.json > environment variable

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
# AZURE_OPENAI_RESOURCE_NAME=       # alternative to BASE_URL
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_DEPLOYMENT_NAME_MAP= # e.g. gpt-4=my-gpt4,gpt-4o=my-gpt4o

# Amazon Bedrock – choose one auth method
# AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Google Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=  # path to service-account key JSON

# Mistral
MISTRAL_API_KEY=

# Groq
GROQ_API_KEY=

# Cerebras
CEREBRAS_API_KEY=

# xAI
XAI_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Vercel AI Gateway
AI_GATEWAY_API_KEY=

# ZAI
ZAI_API_KEY=

# OpenCode Zen / OpenCode Go
OPENCODE_API_KEY=

# Hugging Face
HF_TOKEN=

# Kimi For Coding
KIMI_API_KEY=

# MiniMax
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
